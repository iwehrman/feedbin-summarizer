#!/bin/sh

set -e

staged_files="$(git diff --cached --name-only)"

if [ -z "$staged_files" ]; then
  exit 0
fi

if ! printf '%s\n' "$staged_files" | grep -Eq '(^|/)(manifest\.json|package\.json|package-lock\.json)$|\.((js|mjs|html|css))$'; then
  echo "Skipping lint and tests for docs-only commit."
  exit 0
fi

npm run lint
npm test
