{
  "name": "feedbin-summarizer",
  "version": "0.2.0",
  "description": "A Manifest V3 Chrome extension that adds a `Summary` button to Feedbin's article toolbar and replaces the article body with an LLM-generated summary.",
  "main": "index.js",
  "scripts": {
    "test": "node --test",
    "lint": "eslint . --ext .js,.mjs --cache --cache-location .cache/eslint/",
    "lint:fix": "npm run lint -- --fix",
    "prepare": "husky",
    "build:package": "node scripts/build-package.mjs"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "eslint": "^8.57.1",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "playwright": "^1.58.2"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0"
  }
}
